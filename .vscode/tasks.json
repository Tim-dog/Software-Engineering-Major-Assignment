{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "编译井字棋 (g++)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++20",
                "*.cpp",
                "-o",
                "morpion.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "编译所有 .cpp 文件并链接为 morpion.exe"
        },
        {
            "label": "运行井字棋",
            "type": "shell",
            "command": ".\\morpion.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["编译井字棋 (g++)"],
            "group": {
                "kind": "test",
                "isDefault": false
            },
            "detail": "先编译，然后运行游戏"
        }
    ]
}
