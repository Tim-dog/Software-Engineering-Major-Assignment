@startuml 用例图
' ========================================
' 井字棋游戏 - 用例图
' ========================================

left to right direction
skinparam packageStyle rectangle

actor 玩家1 as P1
actor 玩家2 as P2
actor AI系统 as AI

rectangle "井字棋游戏系统" {
  usecase "开始游戏" as UC1
  usecase "选择游戏模式" as UC2
  usecase "落子" as UC3
  usecase "查看棋盘" as UC4
  usecase "判断胜负/平局" as UC5
  usecase "切换回合" as UC6
  usecase "重新开始" as UC7
  usecase "退出游戏" as UC8
}

P1 --> UC1
P1 --> UC2
P1 --> UC3
P1 --> UC4
P2 --> UC3
AI --> UC3

UC1 ..> UC2 : <<include>>
UC3 ..> UC5 : <<include>>
UC3 ..> UC6 : <<include>>
UC3 ..> UC4 : <<extend>>
UC5 ..> UC4 : <<extend>>

@enduml
